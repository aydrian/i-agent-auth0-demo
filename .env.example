# Auth0 — create a Regular Web App via the Auth0 dashboard or `auth0 apps create`
# See: https://auth0.com/docs/quickstart/webapp/nextjs
AUTH0_SECRET=****                         # openssl rand -hex 32
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=****                         # bare hostname, e.g. your-tenant.us.auth0.com
AUTH0_CLIENT_ID=****
AUTH0_CLIENT_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
# Optional: when set, uploads go to Vercel BLOB. Leave unset to use the S3/MinIO
# configuration below instead (recommended for local development).
BLOB_READ_WRITE_TOKEN=

# S3-compatible storage (used when BLOB_READ_WRITE_TOKEN is unset).
# Local docker-compose defaults below; swap for AWS S3 / Cloudflare R2 / etc. in prod.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=chatbot-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# https://vercel.com/docs/postgres
# Local docker-compose: postgresql://postgres:postgres@localhost:5432/chatbot
POSTGRES_URL=****

# https://vercel.com/docs/redis
# Local docker-compose: redis://localhost:6379
REDIS_URL=****

# Shop API (FastAPI service in docker-compose)
SHOP_API_URL=http://localhost:8000/api/shop
SHOP_API_AUDIENCE=https://api.shop-online-demo.com

# CIBA cron + admin
CRON_SECRET=replace-with-random-string
ADMIN_API_KEY=replace-with-random-string

# Camp AI NY demo — Gmail inbox seeder
# Operator-only OAuth credentials with gmail.insert + gmail.modify scopes
# (kept fully separate from the user's Auth0 Token Vault grant, which stays
# pinned at gmail.readonly). One-time setup via the Google OAuth Playground —
# see docs/demos/camp-ai-ny.md "Pre-flight" for the walk-through.
SEED_GMAIL_CLIENT_ID=
SEED_GMAIL_CLIENT_SECRET=
SEED_GMAIL_REFRESH_TOKEN=
